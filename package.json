{
   "name": "@itsliaaa/starcore",
   "version": "0.0.1-alpha.0",
   "description": "A simple Baileys wrapper for WhatsApp automation",
   "main": "./lib/index.js",
   "types": "./lib/index.d.ts",
   "type": "module",
   "scripts": {
      "preinstall": "node ./engine-requirements.js"
   },
   "exports": {
      ".": {
         "import": "./lib/index.js",
         "require": "./lib/index.js",
         "types": "./lib/index.d.ts"
      }
   },
   "files": [
      "lib/**/*"
   ],
   "engines": {
      "node": ">=20.0.0"
   },
   "repository": {
      "type": "git",
      "url": "git+https://github.com/itsliaaa/starcore.git"
   },
   "keywords": [
      "automation",
      "baileys",
      "bot",
      "interactive-messages",
      "sticker-pack",
      "whatsapp",
      "whatsapp-api",
      "whatsapp-bot",
      "whatsapp-web"
   ],
   "homepage": "https://github.com/itsliaaa/starcore#readme",
   "author": "Lia Wynn",
   "license": "AGPL-3.0-or-later",
   "dependencies": {
      "fflate": "^0.8.3",
      "ffmpeg-static": "^5.3.0",
      "file-type": "^22.0.1",
      "qrcode": "~1.5.4"
   },
   "packageManager": "yarn@1.22.22"
}